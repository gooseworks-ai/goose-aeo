{
  "name": "goose-aeo-dashboard",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.server.json && vite build",
    "dev": "vite",
    "serve": "tsx src/server.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@goose-aeo/core": "file:../../packages/core",
    "@goose-aeo/ui": "file:../../packages/ui",
    "express": "^4.21.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.50",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
