{
  "name": "goose-aeo",
  "version": "0.1.0",
  "description": "Open-source Answer Engine Optimization (AEO) toolkit. Track how AI search engines mention your brand.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "goose-aeo": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aeo",
    "answer-engine-optimization",
    "ai-search",
    "seo",
    "brand-monitoring",
    "perplexity",
    "chatgpt",
    "gemini",
    "claude",
    "grok",
    "deepseek"
  ],
  "author": "Athina AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/athina-ai/goose-aeo.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/athina-ai/goose-aeo",
  "bugs": {
    "url": "https://github.com/athina-ai/goose-aeo/issues"
  },
  "dependencies": {
    "@goose-aeo/core": "0.1.0",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "commander": "^14.0.1",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "inquirer": "^12.10.0",
    "open": "^10.1.2",
    "ora": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.50",
    "tsx": "^4.21.0",
    "vitest": "^3.2.4"
  }
}
